# Database (Postgres / Neon). Local docker-compose maps host port 5439 (avoids clashing
# with a native Postgres on 5432). In production use the Neon connection string.
DATABASE_URL="postgresql://bosco:bosco@localhost:5439/bosco?schema=public"

# Auth
JWT_SECRET="change-me-in-production"
ADMIN_EMAILS="admin@example.com"

# Email (OTP delivery via Resend). If RESEND_API_KEY is empty the OTP code is logged to the console instead.
RESEND_API_KEY=""
RESEND_FROM="Bosco <no-reply@example.com>"

# Image storage (S3). If AWS_S3_BUCKET + creds are set, images upload to S3; otherwise saved locally under ./uploads.
AWS_REGION=""
AWS_S3_BUCKET=""
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""

# HTTP
FRONTEND_ORIGINS="http://localhost:3001,http://localhost:5173"
PUBLIC_URL="http://localhost:3000"
PORT=3000
